{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "permissions": {
    "allow": [
      "Bash(uv run pytest *)",
      "Bash(uv run pyright *)",
      "Bash(uv sync *)",
      "Bash(uv run ruff *)",
      "Bash(bun run *)",
      "Bash(pnpm run *)",
      "Bash(npm run *)",
      "Bash(git submodule update *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)"
    ]
  },
  "filesystem": {
    "allowRead": [
      "~/projects",
      "/root/.cache/uv"
    ]
  },
  "extraKnownMarketplaces": {
    "bmsuisse-skills": {
      "source": {
        "source": "github",
        "repo": "bmsuisse/skills",
        "ref": "main",
        "sparsePaths": [
          "skills",
          "hooks",
          ".claude-plugin"
        ]
      }
    }
  },
  "enabledPlugins": {
    "skills@bmsuisse-skills": true
  }
}